<div class="flex items-center justify-center">
  <div class="flex w-full max-w-4xl bg-white rounded-lg shadow-lg overflow-hidden">
    
    <!-- Left: Odinbook Branding -->
    <div class="hidden md:flex flex-col justify-center items-center bg-blue-600 text-white w-1/2 p-10">
      <h1 class="text-5xl font-extrabold tracking-tight">Odinbook</h1>
      <p class="mt-4 text-lg text-blue-100 text-center">
        Join now and connect with the world around you.
      </p>
    </div>

    <!-- Right: Sign-Up Form -->
    <div class="w-full md:w-1/2 p-8">
      <h2 class="text-3xl font-bold mb-6 text-center text-gray-800">Sign up</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :username, class: "block font-medium mb-1 text-gray-700" %>
          <%= f.text_field :username, autofocus: true, class: "p-2 w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <%= f.label :email, class: "block font-medium mb-1 text-gray-700" %>
          <%= f.email_field :email, autocomplete: "email", class: "p-2 w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <%= f.label :password, class: "block font-medium mb-1 text-gray-700" %>
          <% if @minimum_password_length %>
            <em class="text-xs text-gray-500">(<%= @minimum_password_length %> characters minimum)</em>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "p-2 w-full mt-1 border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "block font-medium mb-1 text-gray-700" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "p-2 w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <%= f.submit "Sign up", class: "w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold py-2 px-4 rounded-md shadow-sm" %>
        </div>
      <% end %>

      <div class="mt-4 text-center text-sm text-gray-600">
        <%= render "devise/shared/links" %>
      </div>
    </div>

  </div>
</div>
